1:08:52 AM [express] POST /api/query-ai 200 in 4162ms :: {"results":[{"sql":"SELECT eo.id AS id_operacao, c.name AS cliente, p.type AS produto, eo.total AS total_usd, eo.embarque_date AS data_embarque, eo.invoice AS nota_fiscal FROM export_orders eo INNER JOIN clients c ON eo.client_id = c.id INNER JOIN products p ON eo.product_id = p.id ORDER BY eo.total DESC LIMIT 1;","rows":[{"id_operacao":27,"cliente":"Packaging Solutions MX","produto":"Standard Brown Kraft","total_usd":"124000.00","data_embarque":"2025-11-05T00:00:00.000Z","nota_fiscal":"INV-2025-021"}],"columns":["id_operacao","cliente","produto","total_usd","data_embarque","nota_fiscal"],"chartSuggestions":[{"type":"kpi","label":"Indicador","reason":"A métrica principal é o valor total da exportação e deve ser exibida como um KPI."},{"type":"table","label":"Tabela","reason":"Mostra detalhes da maior exportação como cliente, produto e outros relacionados."},{"type":"bar","label":"Barras","reason":"Pode ser usado para comparar visualmente o valor desta exportação com outras, caso necessário."}],"chartTitle":"Maior Exportação Realizada","xAxisKey":"id_operacao","yAxisKey":"total_usd","valueLabel":"USD"}]}
1:08:53 AM [express] POST /api/query-ai/history 200 in 524ms :: {"id":7,"question":"Qual foi a maior exportação que eu ja fiz ate hoje","result":[{"sql":"SELECT eo.id AS id_operacao, c.name AS cliente, p.type AS produto, eo.total AS total_usd, eo.embarque_date AS data_embarque, eo.invoice AS nota_fiscal FROM export_orders eo INNER JOIN clients c ON eo.client_id = c.id INNER JOIN products p ON eo.product_id = p.id ORDER BY eo.total DESC LIMIT 1;","rows":[{"cliente":"Packaging Solutions MX","produto":"Standard Brown Kraft","total_usd":"124000.00","id_operacao":27,"nota_fiscal":"INV-2025-021","data_embarque":"2025-11-05T00:00:00.000Z"}],"columns":["id_operacao","cliente","produto","total_usd","data_embarque","nota_fiscal"],"xAxisKey":"id_operacao","yAxisKey":"total_usd","chartTitle":"Maior Exportação Realizada","valueLabel":"USD","chartSuggestions":[{"type":"kpi","label":"Indicador","reason":"A métrica principal é o valor total da exportação e deve ser exibida como um KPI."},{"type":"table","label":"Tabela","reason":"Mostra detalhes da maior exportação como cliente, produto e outros relacionados."},{"type":"bar","label":"Barras","reason":"Pode ser usado para comparar visualmente o valor desta exportação com outras, caso necessário."}]}],"favoritado":false,"tituloFavorito":null,"createdAt":"2026-03-11T01:08:52.552Z"}
1:08:53 AM [express] GET /api/query-ai/history 200 in 2ms :: [{"id":2,"question":"Qual o valor total faturado por produto?","result":[{"sql":"SELECT products.type AS tipo_produto, SUM(export_orders.total) AS total_faturado_usd FROM export_orders JOIN products ON export_orders.product_id = products.id GROUP BY products.type ORDER BY total_faturado_usd DESC LIMIT 50","rows":[{"tipo_produto":"Standard Brown Kraft","total_faturado_usd":"1091200.00"},{"tipo_produto":"Extensible Kraft","total_faturado_usd":"799200.00"},{"tipo_produto":"Sack Kraft","total_faturado_usd":"407793.82"},{"tipo_produto":"White Top Kraft","total_faturado_usd":"374000.00"}],"columns":["tipo_produto","total_faturado_usd"],"xAxisKey":"tipo_produto","yAxisKey":"total_faturado_usd","chartTitle":"Valor Total Faturado por Produto","valueLabel":"USD","chartSuggestions":[{"type":"bar","label":"Barras","reason":"Permite comparar o valor total faturado entre diferentes produtos"},{"type":"pie","label":"Pizza","reason":"Visualiza a proporção de faturamento de cada produto em relação ao todo"},{"type":"table","label":"Tabela","reason":"Lista detalhada dos valores faturados por produto"}]}],"favoritado":true,"tituloFavorito":null,"createdAt":"2026-03-09T23:20:02.054Z"},{"id":3,"question":"qual meus tops 3 clientes ?","result":[{"sql":"SELECT clients.name AS cliente, SUM(export_orders.total) AS total_usd FROM export_orders JOIN clients ON export_orders.client_id = clients.id GROUP BY clients.name ORDER BY total_usd DESC LIMIT 3","rows":[{"cliente":"Papelera del Sur S.A.","total_usd":"611100.00"},{"cliente":"Corrugados del Plata","total_usd":"588200.00"},{"cliente":"Packaging Solutions MX","total_usd":"373200.00"}],"columns":["cliente","total_usd"],"xAxisKey":"cliente","yAxisKey":"total_usd","chartTitle":"Top 3 Clientes por Receita de Exportação","valueLabel":"USD","chartSuggestions":[{"type":"bar","label":"Barras","reason":"Adequado para comparar os valores totais entre os top 3 clientes"},{"type":"pie","label"