11:40:49 PM [express] GET /api/query-ai/history 304 in 3ms :: [{"id":1,"question":"Qual o total de exportações por cliente?","result":[{"sql":"SELECT clients.name AS cliente, SUM(export_orders.total) AS total_exportado_usd FROM export_orders JOIN clients ON export_orders.client_id = clients.id GROUP BY clients.name ORDER BY total_exportado_usd DESC LIMIT 50","rows":[{"cliente":"Papelera del Sur S.A.","total_exportado_usd":"611100.00"},{"cliente":"Corrugados del Plata","total_exportado_usd":"588200.00"},{"cliente":"Packaging Solutions MX","total_exportado_usd":"373200.00"},{"cliente":"Industrias Guarani","total_exportado_usd":"312393.82"},{"cliente":"Empaques Santiago Ltda","total_exportado_usd":"303400.00"},{"cliente":"PackPro Uruguay","total_exportado_usd":"293600.00"},{"cliente":"Embalajes Bolivia Ltda","total_exportado_usd":"190300.00"}],"columns":["cliente","total_exportado_usd"],"xAxisKey":"cliente","yAxisKey":"total_exportado_usd","chartTitle":"Total de Exportações por Cliente","valueLabel":"USD","chartSuggestions":[{"type":"bar","label":"Barras","reason":"Permite comparar visualmente o volume exportado entre diferentes clientes"},{"type":"pie","label":"Pizza","reason":"Oferece uma visão percentual da participação de cada cliente no total exportado"},{"type":"table","label":"Tabela","reason":"Apresenta os dados de forma clara e detalhada para análise textual"}]}],"favoritado":true,"tituloFavorito":null,"createdAt":"2026-03-09T23:19:41.730Z"},{"id":2,"question":"Qual o valor total faturado por produto?","result":[{"sql":"SELECT products.type AS tipo_produto, SUM(export_orders.total) AS total_faturado_usd FROM export_orders JOIN products ON export_orders.product_id = products.id GROUP BY products.type ORDER BY total_faturado_usd DESC LIMIT 50","rows":[{"tipo_produto":"Standard Brown Kraft","total_faturado_usd":"1091200.00"},{"tipo_produto":"Extensible Kraft","total_faturado_usd":"799200.00"},{"tipo_produto":"Sack Kraft","total_faturado_usd":"407793.82"},{"tipo_produto":"White Top Kraft","total_faturado_usd":"374000.00"}],"columns":["tipo_produto","total_faturado_usd"],"xAxisKey":"tipo_produto","yAxisKey":"total_faturado_usd","chartTitle":"Valor Total Faturado por Produto","valueLabel":"USD","chartSuggestions":[{"type":"bar","label":"Barras","reason":"Permite comparar o valor total faturado entre diferentes produtos"},{"type":"pie","label":"Pizza","reason":"Visualiza a proporção de faturamento de cada produto em relação ao todo"},{"type":"table","label":"Tabela","reason":"Lista detalhada dos valores faturados por produto"}]}],"favoritado":true,"tituloFavorito":null,"createdAt":"2026-03-09T23:20:02.054Z"},{"id":3,"question":"qual meus tops 3 clientes ?","result":[{"sql":"SELECT clients.name AS cliente, SUM(export_orders.total) AS total_usd FROM export_orders JOIN clients ON export_orders.client_id = clients.id GROUP BY clients.name ORDER BY total_usd DESC LIMIT 3","rows":[{"cliente":"Papelera del Sur S.A.","total_usd":"611100.00"},{"cliente":"Corrugados del Plata","total_usd":"588200.00"},{"cliente":"Packaging Solutions MX","total_usd":"373200.00"}],"columns":["cliente","total_usd"],"xAxisKey":"cliente","yAxisKey":"total_usd","chartTitle":"Top 3 Clientes por Receita de Exportação","valueLabel":"USD","chartSuggestions":[{"type":"bar","label":"Barras","reason":"Adequado para comparar os valores totais entre os top 3 clientes"},{"type":"pie","label":"Pizza","reason":"Útil para mostrar as proporções entre os top 3 clientes"},{"type":"table","label":"Tabela","reason":"Útil para exibir os dados detalhados dos top 3 clientes de forma objetiva"}]}],"favoritado":false,"tituloFavorito":null,"createdAt":"2026-03-09T23:22:14.520Z"},{"id":4,"question":"qual meus tops 3 clientes ? e me de os valores de faturamento de cada um","result":[{"sql":"SELECT clients.name AS cliente, SUM(export_orders.total) AS faturamento_total FROM export_orders JOIN clients ON export_orders.client_id = clients.id GROUP BY clients.name ORDER BY faturamento_total DESC LIMIT 3","rows":[{"cliente":"Papelera del Sur S.A.","faturamento_total":"611100.00"},{"cliente":"Corrugados del Plata","faturamento_total":"588200.00"},{"cliente":"Packaging Solutions MX","faturamento_total":"373200.00"}],"columns":["cliente","faturamento_total"],"xAxisKey":"cliente","yAxisKey":"faturamento_total","chartTitle":"Top 3 Clientes por Faturamento","valueLabel":"USD","chartSuggestions":[{"type":"bar","label":"Barras","reason":"Adequado para comparação entre os três principais clientes"},{"type":"pie","label":"Pizza","reason":"Adequado para representar a participação percentual de cada cliente no total"},{"type":"table","label":"Tabela","reason":"Adequado para exibição detalhada, com valores exatos"}]}],"favoritado":false,"tituloFavorito":null,"createdAt":"2026-03-09T23:22:36.671Z"},{"id":5,"question":"Me mostre quantas cotações tivemos no ultimo mês","result":[{"sql":"SELECT COUNT(*) AS total_cotacoes FROM quotations WHERE created_at >= DATE_TRUNC('month', CURRENT_DATE - INTERVAL '1 month') AND created_at < DATE_TRUNC('month', CURRENT_DATE);","rows":[{"total_cotacoes":"3"}],"columns":["total_cotacoes"],"xAxisKey":"total_cotacoes","yAxisKey":"total_cotacoes","chartTitle":"Total de Cotações no Último Mês","valueLabel":"Qtd","chartSuggestions":[{"type":"kpi","label":"Indicador","reason":"Mostra de forma direta o número total de cotações do último mês."},{"type":"table","label":"Tabela","reason":"Adequado para exibir o valor exato em um formato tabular, caso necessário."},{"type":"bar","label":"Barras","reason":"Pode ser usado para ilustrar o valor isolado como um gráfico visual."}]}],"favoritado":false,"tituloFavorito":null,"createdAt":"2026-03-09T23:25:07.358Z"},{"id":6,"question":"Mostre o faturamento mensal em USD dos últimos 6 meses","result":[{"sql":"SELECT to_char(export_orders.embarque_date, 'YYYY-MM') AS mes, SUM(export_orders.total) AS faturamento_usd FROM export_orders WHERE export_orders.embarque_date >= CURRENT_DATE - INTERVAL '6 months' GROUP BY to_char(export_orders.embarque_date, 'YYYY-MM') ORDER BY mes","rows":[{"mes":"2025-09","faturamento_usd":"69600.00"},{"mes":"2025-10","faturamento_usd":"181900.00"},{"mes":"2025-11","faturamento_usd":"278400.00"},{"mes":"2025-12","faturamento_usd":"206600.00"},{"mes":"2026-01","faturamento_usd":"337600.00"},{"mes":"2026-02","faturamento_usd":"378600.00"},{"mes":"2026-03","faturamento_usd":"58000.00"}],"columns":["mes","faturamento_usd"],"xAxisKey":"mes","yAxisKey":"faturamento_usd","chartTitle":"Faturamento mensal em USD nos últimos 6 meses","valueLabel":"USD","chartSuggestions":[{"type":"line","label":"Linha","reason":"A linha é ideal para demonstrar tendências ao longo do tempo."},{"type":"bar","label":"Barras","reason":"Útil para comparar o faturamento de cada mês de forma clara."},{"type":"table","label":"Tabela","reason":"Permite visualizar os dados exatos para cada mês."}]}],"favoritado":true,"tituloFavorito":null,"createdAt":"2026-03-09T23:25:31.255Z"}]
