11:32:06 PM [express] GET /api/query-ai/favorites 304 in 3ms :: [{"id":1,"question":"Qual o total de exportações por cliente?","result":[{"sql":"SELECT clients.name AS cliente, SUM(export_orders.total) AS total_exportado_usd FROM export_orders JOIN clients ON export_orders.client_id = clients.id GROUP BY clients.name ORDER BY total_exportado_usd DESC LIMIT 50","rows":[{"cliente":"Papelera del Sur S.A.","total_exportado_usd":"611100.00"},{"cliente":"Corrugados del Plata","total_exportado_usd":"588200.00"},{"cliente":"Packaging Solutions MX","total_exportado_usd":"373200.00"},{"cliente":"Industrias Guarani","total_exportado_usd":"312393.82"},{"cliente":"Empaques Santiago Ltda","total_exportado_usd":"303400.00"},{"cliente":"PackPro Uruguay","total_exportado_usd":"293600.00"},{"cliente":"Embalajes Bolivia Ltda","total_exportado_usd":"190300.00"}],"columns":["cliente","total_exportado_usd"],"xAxisKey":"cliente","yAxisKey":"total_exportado_usd","chartTitle":"Total de Exportações por Cliente","valueLabel":"USD","chartSuggestions":[{"type":"bar","label":"Barras","reason":"Permite comparar visualmente o volume exportado entre diferentes clientes"},{"type":"pie","label":"Pizza","reason":"Oferece uma visão percentual da participação de cada cliente no total exportado"},{"type":"table","label":"Tabela","reason":"Apresenta os dados de forma clara e detalhada para análise textual"}]}],"favoritado":true,"tituloFavorito":null,"createdAt":"2026-03-09T23:19:41.730Z"},{"id":2,"question":"Qual o valor total faturado por produto?","result":[{"sql":"SELECT products.type AS tipo_produto, SUM(export_orders.total) AS total_faturado_usd FROM export_orders JOIN products ON export_orders.product_id = products.id GROUP BY products.type ORDER BY total_faturado_usd DESC LIMIT 50","rows":[{"tipo_produto":"Standard Brown Kraft","total_faturado_usd":"1091200.00"},{"tipo_produto":"Extensible Kraft","total_faturado_usd":"799200.00"},{"tipo_produto":"Sack Kraft","total_faturado_usd":"407793.82"},{"tipo